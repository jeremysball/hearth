PORT=8443
# 0.0.0.0 listens on every interface the host has, not just your tailnet —
# if the host also has a LAN/Wi-Fi interface, anything on that network can
# reach this port too. Bind to your Tailscale IP instead (`tailscale ip -4`)
# to scope this to tailnet-only, e.g. HOST=100.x.y.z.
HOST=0.0.0.0
DB_PATH=hearth.db
# Leave STATIC_DIR empty to serve the frontend embedded in the binary.
# Set it to a path (e.g. "." when running from the repo root) to serve
# frontend files live from disk instead, for local development.
# Do NOT set this in a .env used by docker-compose — the Docker image
# ships no on-disk frontend files, so disk mode there 404s everything.
STATIC_DIR=
CERT_FILE=
KEY_FILE=

# GeoIP request-log enrichment (optional)
# Set GEOIP_ENABLED=true and provide either a local GeoLite2-City.mmdb path or
# a MaxMind license key so Hearth can download the database on startup.
GEOIP_ENABLED=false
GEOIP_DB_PATH=
MAXMIND_LICENSE_KEY=

# OAuth (optional — anonymous accounts work without these)
# PUBLIC_BASE_URL must match the origin users reach the app at (no trailing slash).
# Register <PUBLIC_BASE_URL>/api/auth/google/callback as an authorized redirect URI
# in Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID.
PUBLIC_BASE_URL=https://your-host
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Token pepper (required) — HMAC key for session cookies, invite links,
# launch tokens, and pending-auth tokens. Comma-separated, current pepper
# first, for rotation. Each entry must be at least 32 bytes.
# Generate one with: openssl rand -hex 32
PEPPER=
