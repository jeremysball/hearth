{
  "name": "hearth",
  "private": true,
  "description": "Hearth baby tracker PWA",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node tests/run.js",
    "test:spinner": "node tests/spinner.test.js",
    "lint": "eslint .",
